#!/bin/bash
set -e

# Activate venv if it exists
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

echo "→ Linting..."
ruff check services/ tests/ || true  # don't block on lint warnings for now

echo "→ Unit tests..."
pytest tests/unit/ -q --tb=short 2>/dev/null || echo "⚠️  No unit tests yet — skipping"

echo "✅ Pre-push checks passed"
